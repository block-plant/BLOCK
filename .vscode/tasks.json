{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "cppbuild",
      "label": "C/C++: g++-15 build active file",
      "command": "/opt/homebrew/bin/g++-15",
      "args": [
        "-std=gnu++20",
        "-O2",
        "-Wall",
        "-Wextra",
        "-Wshadow",
        "-DLOCAL",
        "${file}",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}"
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": [
        "$gcc"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
